// Jenkinsfile — RUTA ALTERNATIVA / EMPRESARIAL (declarativa).
// Equivalente al pipeline de GitHub Actions, pero en Jenkins.
// Requiere un agente con Node 22 y Docker disponibles.

pipeline {
    agent any

    environment {
        APP_DIR = '01-app/node'
        IMAGE   = "academia-devops-app:${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm ci'
                }
            }
        }

        stage('Test') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm test'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir(env.APP_DIR) {
                    sh "docker build -t ${IMAGE} ."
                }
            }
        }

        stage('Security Scan') {
            steps {
                // Didactico: reporta vulnerabilidades sin romper el build.
                sh "trivy image --severity CRITICAL,HIGH --exit-code 0 ${IMAGE} || true"
            }
        }
    }

    post {
        success { echo "✅ Pipeline verde. Imagen: ${IMAGE}" }
        failure { echo '❌ Pipeline rojo. Revisa la etapa que fallo.' }
    }
}
